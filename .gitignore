# Purpose: Keep local artifacts, secrets, generated files, and agent state out of git.
# Responsibilities:
#   - Ignore Python cache/build outputs and test tooling state.
#   - Ignore local runtime data and SQLite databases.
#   - Ignore local environment/secrets files while keeping .env.example tracked.
#   - Ignore local editor/agent workspace files.
# Non-scope:
#   - Managing global gitignore behavior outside this repository.

# Python caches and tooling
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
.venv/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Packaging/build artifacts
build/
dist/
dogfood-output/
*.egg-info/
src/*.egg-info/
src/cloop/static/dist/
# Frontend OpenAPI schema exports are local/generated.
# Contract types in frontend/src/generated/ are intentionally committed.
frontend/openapi.json

# Project runtime data
data/
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm

# Environment / secrets
.env
.env.*
!.env.example

# Local tooling/agent state
.repoprompt/
.ralph/
.codex/
.pi
.pi/
.claude/
CLAUDE.md
.scratchpad.md
node_modules/
frontend/.vite/

# Editor / OS noise
.DS_Store
.vscode/
.idea/
*.log
.playwright-cli/
output

# Ralph debug logs (raw/unredacted; do not commit)
.ralph/logs/

# Ralph parallel mode workspace directories
.ralph/workspaces/
