{
  "name": "cloop-frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "type": "module",
  "engines": {
    "node": ">=25.8.2"
  },
  "scripts": {
    "generate:openapi": "sh -c 'cd .. && uv run --locked python scripts/export_frontend_openapi.py'",
    "generate:contracts": "pnpm run generate:openapi && rm -rf ./src/generated && openapi-ts --file ./openapi-ts.config.ts && rm -f ./src/generated/index.ts",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "test": "vitest run",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.97.1",
    "@types/node": "^25.6.1",
    "jsdom": "^29.1.1",
    "typescript": "6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
