{
  "name": "cloop-frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "generate:openapi": "sh -c 'cd .. && uv run --locked python scripts/export_frontend_openapi.py'",
    "generate:contracts": "pnpm run generate:openapi && rm -rf ./src/generated && openapi-ts --file ./openapi-ts.config.ts && rm -f ./src/generated/index.ts",
    "dev": "pnpm run generate:contracts && vite",
    "typecheck": "pnpm run generate:contracts && tsc --noEmit",
    "build": "pnpm run generate:contracts && vite build",
    "test": "pnpm run generate:contracts && vitest run --passWithNoTests",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@hey-api/openapi-ts": "0.94.5",
    "jsdom": "^29.0.1",
    "typescript": "6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
