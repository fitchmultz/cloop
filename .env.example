CLOOP_LLM_MODEL=ollama/llama3
CLOOP_EMBED_MODEL=ollama/nomic-embed-text
CLOOP_DATA_DIR=./data
CLOOP_MAX_FILE_SIZE_MB=50
CLOOP_CORE_DB_PATH=
CLOOP_RAG_DB_PATH=
CLOOP_DEFAULT_TOP_K=5
CLOOP_CHUNK_SIZE=800
CLOOP_LLM_TIMEOUT=30.0
CLOOP_INGEST_TIMEOUT=60.0
CLOOP_EMBED_TIMEOUT=30.0
CLOOP_ORGANIZER_MODEL=gemini/gemini-3-flash-preview
CLOOP_ORGANIZER_TIMEOUT=20.0
CLOOP_AUTOPILOT_ENABLED=true
CLOOP_AUTOPILOT_AUTOAPPLY_MIN_CONFIDENCE=0.85
CLOOP_TOOL_MODE=manual
CLOOP_STREAM_DEFAULT=false
CLOOP_EMBED_STORAGE=dual
CLOOP_SQLITE_VECTOR_EXTENSION=
CLOOP_VECTOR_MODE=python
CLOOP_OPENAI_API_BASE=
CLOOP_OPENAI_API_KEY=
CLOOP_GOOGLE_API_KEY=
CLOOP_OLLAMA_API_BASE=
CLOOP_LMSTUDIO_API_BASE=
CLOOP_OPENROUTER_API_BASE=
LITELLM_API_KEY=

# Prioritization thresholds (optional, defaults shown)
CLOOP_PRIORITIZATION_DUE_WINDOW_HOURS=72.0
CLOOP_PRIORITIZATION_DUE_SOON_HOURS=48.0
CLOOP_PRIORITIZATION_QUICK_WIN_MINUTES=15
CLOOP_PRIORITIZATION_HIGH_LEVERAGE_THRESHOLD=0.7

# Priority weights for scoring (optional, defaults shown)
# Higher values = more influence on priority score
CLOOP_PRIORITY_WEIGHT_DUE=1.0
CLOOP_PRIORITY_WEIGHT_URGENCY=0.7
CLOOP_PRIORITY_WEIGHT_IMPORTANCE=0.9
# Penalties reduce score (higher = stronger penalty)
CLOOP_PRIORITY_WEIGHT_TIME_PENALTY=0.2
CLOOP_PRIORITY_WEIGHT_ACTIVATION_PENALTY=0.3

# Related loops configuration
# Maximum number of candidate embeddings to consider for similarity search.
# Lower values reduce memory usage but may miss relevant matches.
# Default: 1000 (suitable for ~1GB RAM systems with 768-dim embeddings)
# CLOOP_RELATED_MAX_CANDIDATES=1000

# Backup configuration
# Directory to store backup archives (default: data_dir/backups)
# CLOOP_BACKUP_DIR=
# Number of backups to keep during rotation (default: 10)
# CLOOP_BACKUP_KEEP_COUNT=10
# Enable ZIP compression for backups (default: true)
# CLOOP_BACKUP_COMPRESS=true

# Idempotency configuration
# Time-to-live in seconds for idempotency keys (default: 86400 = 24 hours)
# CLOOP_IDEMPOTENCY_TTL_SECONDS=86400
# Maximum allowed length for idempotency keys (default: 255)
# CLOOP_IDEMPOTENCY_MAX_KEY_LENGTH=255
