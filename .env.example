# Root directory for the project (defaults to current working directory)
CLOOP_ROOT_DIR=

# Core LLM and embedding configuration
CLOOP_LLM_MODEL=ollama/llama3
CLOOP_EMBED_MODEL=ollama/nomic-embed-text
CLOOP_DATA_DIR=./data
CLOOP_MAX_FILE_SIZE_MB=50

# Database paths (optional, defaults to data_dir/*.db)
CLOOP_CORE_DB_PATH=
CLOOP_RAG_DB_PATH=

# Retrieval and chunking settings
CLOOP_DEFAULT_TOP_K=5
CLOOP_CHUNK_SIZE=800

# Timeout settings (seconds)
CLOOP_LLM_TIMEOUT=30.0
CLOOP_INGEST_TIMEOUT=60.0
CLOOP_EMBED_TIMEOUT=30.0

# Organizer LLM settings
CLOOP_ORGANIZER_MODEL=gemini/gemini-3-flash-preview
CLOOP_ORGANIZER_TIMEOUT=20.0

# Autopilot settings
CLOOP_AUTOPILOT_ENABLED=true
CLOOP_AUTOPILOT_AUTOAPPLY_MIN_CONFIDENCE=0.85

# Tool mode: manual, llm, or none
CLOOP_TOOL_MODE=manual

# Streaming and storage settings
CLOOP_STREAM_DEFAULT=false
CLOOP_EMBED_STORAGE=dual

# SQLite vector extension path (optional)
CLOOP_SQLITE_VECTOR_EXTENSION=

# Vector search mode: python, sqlite, or auto
CLOOP_VECTOR_MODE=python

# API configuration (fill in your API keys as needed)
CLOOP_OPENAI_API_BASE=
CLOOP_OPENAI_API_KEY=
CLOOP_GOOGLE_API_KEY=
CLOOP_OLLAMA_API_BASE=
CLOOP_LMSTUDIO_API_BASE=
CLOOP_OPENROUTER_API_BASE=
LITELLM_API_KEY=

# Prioritization thresholds (optional, defaults shown)
CLOOP_PRIORITIZATION_DUE_WINDOW_HOURS=72.0
CLOOP_PRIORITIZATION_DUE_SOON_HOURS=48.0
CLOOP_PRIORITIZATION_QUICK_WIN_MINUTES=15
CLOOP_PRIORITIZATION_HIGH_LEVERAGE_THRESHOLD=0.7

# Priority weights for scoring (optional, defaults shown)
# Higher values = more influence on priority score
CLOOP_PRIORITY_WEIGHT_DUE=1.0
CLOOP_PRIORITY_WEIGHT_URGENCY=0.7
CLOOP_PRIORITY_WEIGHT_IMPORTANCE=0.9
# Penalties reduce score (higher = stronger penalty)
CLOOP_PRIORITY_WEIGHT_TIME_PENALTY=0.2
CLOOP_PRIORITY_WEIGHT_ACTIVATION_PENALTY=0.3
# Blocked dependency penalty - applied when loop has open dependencies (default: 10.0)
CLOOP_PRIORITY_WEIGHT_BLOCKED_PENALTY=10.0

# Related loops configuration
# Similarity threshold for matching related loops (0.0-1.0, higher = stricter match)
CLOOP_RELATED_SIMILARITY_THRESHOLD=0.78
# Duplicate detection threshold (0.9-1.0, higher = stricter match for near-identical content)
# Default: 0.95 (must be greater than related similarity threshold)
CLOOP_DUPLICATE_SIMILARITY_THRESHOLD=0.95
# Maximum number of candidate embeddings to consider for similarity search.
# Lower values reduce memory usage but may miss relevant matches.
# Default: 1000 (suitable for ~1GB RAM systems with 768-dim embeddings)
CLOOP_RELATED_MAX_CANDIDATES=1000

# Backup configuration
# Directory to store backup archives (default: data_dir/backups)
CLOOP_BACKUP_DIR=
# Number of backups to keep during rotation (default: 10)
CLOOP_BACKUP_KEEP_COUNT=10
# Enable ZIP compression for backups (default: true)
CLOOP_BACKUP_COMPRESS=true

# Idempotency configuration
# Time-to-live in seconds for idempotency keys (default: 86400 = 24 hours)
CLOOP_IDEMPOTENCY_TTL_SECONDS=86400
# Maximum allowed length for idempotency keys (default: 255)
CLOOP_IDEMPOTENCY_MAX_KEY_LENGTH=255

# LLM Retry Settings (for transient error handling)
# Maximum number of retry attempts for LLM/embedding API failures
CLOOP_LLM_MAX_RETRIES=3
# Initial wait time in seconds before first retry (exponential backoff)
CLOOP_LLM_RETRY_MIN_WAIT=2.0
# Maximum wait time in seconds between retries
CLOOP_LLM_RETRY_MAX_WAIT=60.0

# Webhook configuration (for external integrations)
# Maximum number of retry attempts for failed webhook deliveries
CLOOP_WEBHOOK_MAX_RETRIES=5
# Base delay in seconds between retries (exponential backoff)
CLOOP_WEBHOOK_RETRY_BASE_DELAY=2.0
# Maximum delay cap for retry backoff in seconds
CLOOP_WEBHOOK_RETRY_MAX_DELAY=300.0
# Timeout for individual webhook requests in seconds
CLOOP_WEBHOOK_TIMEOUT_SECONDS=30.0
# Interval for heartbeat/keepalive during long webhook operations in seconds
CLOOP_WEBHOOK_HEARTBEAT_INTERVAL=30.0

# Claim configuration (for loop locking/ownership)
# Default time-to-live for claims in seconds
CLOOP_CLAIM_DEFAULT_TTL_SECONDS=300
# Maximum allowed claim TTL in seconds
CLOOP_CLAIM_MAX_TTL_SECONDS=3600
# Number of random bytes in claim tokens
CLOOP_CLAIM_TOKEN_BYTES=32

# Review cohort thresholds (for stale-loop detection)
# Hours before a loop is considered stale (no updates)
CLOOP_REVIEW_STALE_HOURS=72.0
# Hours before a blocked loop triggers review
CLOOP_REVIEW_BLOCKED_HOURS=48.0
# Hours before a due loop triggers review
CLOOP_REVIEW_DUE_SOON_HOURS=48.0

# Next-loop candidate limit (default: 500)
# Bounds the number of candidates fetched for /loops/next endpoint
# Lower values reduce latency but may miss items; higher values increase coverage
# Note: The limit is applied BEFORE dependency filtering. If many candidates have
# open dependencies, you may see fewer results than the limit suggests.
# CLOOP_NEXT_CANDIDATES_LIMIT=500

# Operation metrics configuration (default: false)
# Enable in-memory counters for loop lifecycle operations (capture, update, transitions)
# Enables operational monitoring via /loops/metrics endpoint with operation_metrics field
CLOOP_OPERATION_METRICS_ENABLED=false

# Scheduler configuration (for proactive assistant routines)
# Enable/disable the background scheduler (default: true)
CLOOP_SCHEDULER_ENABLED=true
# Hours between daily review generation (default: 24.0)
CLOOP_SCHEDULER_DAILY_REVIEW_INTERVAL_HOURS=24.0
# Hours between weekly review generation (default: 168.0 = 7 days)
CLOOP_SCHEDULER_WEEKLY_REVIEW_INTERVAL_HOURS=168.0
# Hours between due-soon nudge checks (default: 1.0)
CLOOP_SCHEDULER_DUE_SOON_NUDGE_INTERVAL_HOURS=1.0
# Hours between stale rescue checks (default: 6.0)
CLOOP_SCHEDULER_STALE_RESCUE_INTERVAL_HOURS=6.0
